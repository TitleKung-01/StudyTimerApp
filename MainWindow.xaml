<Window x:Class="StudyTimerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudyTimerApp"
        mc:Ignorable="d"
        Title="Focus Reading Timer" Height="680" Width="800"
        Background="#11111B" Foreground="#CDD6F4"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1DB954"/> <!-- Spotify Green -->
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1ed760"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1aa34a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A2A35"/>
                                <Setter Property="Foreground" Value="#A6ADC8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Timer Display -->
        <TextBlock Text="{Binding TimeDisplay}" FontSize="110" 
                   HorizontalAlignment="Center" FontWeight="UltraBlack" 
                   Margin="0,10,0,20" Foreground="#FFFFFF"/>

        <!-- Time Selectors -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="10 Min" Command="{Binding SetTimeCommand}" CommandParameter="10" Style="{StaticResource ModernButton}" Margin="8"/>
            <Button Content="25 Min" Command="{Binding SetTimeCommand}" CommandParameter="25" Style="{StaticResource ModernButton}" Margin="8"/>
            <Button Content="50 Min" Command="{Binding SetTimeCommand}" CommandParameter="50" Style="{StaticResource ModernButton}" Margin="8"/>
        </StackPanel>

        <!-- Link Input -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <TextBlock Text="Youtube Music URL:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15" FontWeight="SemiBold" Foreground="#B3B3B3"/>
            <TextBox Text="{Binding MediaUrl, UpdateSourceTrigger=PropertyChanged}" Width="380" Padding="12" FontSize="14" 
                     Background="#242424" Foreground="#FFFFFF" BorderBrush="Transparent" BorderThickness="0" 
                     IsEnabled="{Binding CanEditSettings}"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="▶ START FOCUS" Command="{Binding StartCommand}" Style="{StaticResource ModernButton}" FontSize="16" Width="160" Margin="10"/>
            <Button Content="⏸ STOP" Command="{Binding StopCommand}" Style="{StaticResource ModernButton}" FontSize="16" Width="100" Margin="10" Background="#313244"/>
            <Button Content="🔄 RESET" Command="{Binding ResetCommand}" Style="{StaticResource ModernButton}" FontSize="16" Width="100" Margin="10" Background="#313244"/>
        </StackPanel>

        <!-- Spotify-like Media Player -->
        <Border Grid.Row="4" CornerRadius="12" Background="#181818" Margin="0,15" Padding="20">
            <Grid>
                <!-- Loading State -->
                <TextBlock Text="Loading ad-free music stream..." FontSize="16" FontWeight="SemiBold" Foreground="#1DB954"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsLoadingMusic, Converter={StaticResource BoolToVis}}"/>
                
                <!-- Track Info -->
                <Grid Visibility="{Binding CurrentTrack, ConverterParameter=Inverse, Converter={StaticResource BoolToVis}}">
                    <!-- Default State when empty (Handled by bindings) -->
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentTrack}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Thumbnail -->
                    <Border CornerRadius="8" ClipToBounds="True" Width="80" Height="80" VerticalAlignment="Center" Margin="0,0,20,0">
                        <Image Source="{Binding CurrentTrack.ThumbnailUrl}" Stretch="UniformToFill"/>
                    </Border>
                    
                    <!-- Track Details -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="NOW PLAYING (AD-FREE)" Foreground="#1DB954" FontWeight="Bold" FontSize="11" Margin="0,0,0,5" />
                        <TextBlock Text="{Binding CurrentTrack.Title}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="18" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentTrack.Author}" Foreground="#B3B3B3" FontSize="14" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
                
                <MediaElement x:Name="PlayerMediaElement" Visibility="Collapsed" LoadedBehavior="Manual" UnloadedBehavior="Stop"/>
            </Grid>
        </Border>
    </Grid>
</Window>
